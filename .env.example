# Environment: 'localnet' (Aztec localnet + Anvil) or 'production' (Aztec devnet + Base Sepolia)
AZTEC_ENV=localnet

# Aztec node URL
AZTEC_NODE_URL=http://localhost:8080

# EVM RPC URL
EVM_RPC_URL=http://localhost:8545

# EVM chain: 'foundry' for Anvil, 'baseSepolia' for Base Sepolia
EVM_CHAIN=foundry

# Private key for the bridge operator (mints bUSDC on EVM side)
EVM_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Canonical SponsoredFPC address
SPONSORED_FPC_ADDRESS=0x09a4df73aa47f82531a038d1d51abfc85b27665c4b7ca751e2d4fa9f19caffb2

# EVM token address (set after deploying bUSDC, or loaded from evm-deployment.json)
# EVM_TOKEN_ADDRESS=

# Server port
PORT=3001
